---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Search" description="Search the full text of The Covenant Rendering Bible translation." canonical="/search">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-3xl md:text-4xl font-serif font-medium text-stone-800 mb-3">
      Search the Text
    </h1>
    <p class="text-stone-500 mb-10 leading-relaxed">
      Search across every book and chapter of The Covenant Rendering.
    </p>
    <div id="search"></div>
  </section>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <style is:global>
    :root {
      --pagefind-ui-scale: 1;
      --pagefind-ui-primary: #0d9488;
      --pagefind-ui-text: #44403c;
      --pagefind-ui-background: #fffbf5;
      --pagefind-ui-border: #e7e0d5;
      --pagefind-ui-tag: #f0ebe3;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 0.5rem;
      --pagefind-ui-image-border-radius: 0.5rem;
      --pagefind-ui-image-box-ratio: 3 / 2;
      --pagefind-ui-font: 'Inter', sans-serif;
    }
    .pagefind-ui__search-input {
      font-size: 1rem !important;
      padding: 0.75rem 1rem !important;
    }
    .pagefind-ui__result-link {
      color: #0d9488 !important;
      font-family: 'Cormorant Garamond', serif !important;
      font-size: 1.2rem !important;
    }
    .pagefind-ui__result-link:hover {
      color: #0f766e !important;
    }
    .pagefind-ui__result-excerpt {
      font-size: 0.925rem !important;
      line-height: 1.7 !important;
      color: #57534e !important;
    }
    mark.pagefind-ui__result-highlight {
      background: #ccfbf1 !important;
      color: #0d9488 !important;
      padding: 0.1em 0.2em;
      border-radius: 2px;
    }
  </style>

  <script is:inline>
    window.addEventListener('DOMContentLoaded', function() {
      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function() {
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
        });
      };
      document.head.appendChild(script);
    });
  </script>
</Layout>
