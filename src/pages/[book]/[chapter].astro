---
import Layout from '../../layouts/Layout.astro';
import VerseCard from '../../components/VerseCard.astro';
import TraditionStack from '../../components/TraditionStack.astro';
import { getAvailableBooks, getAllChapterNums, loadChapter, getBook, SOURCE_TEXT_LABELS, getStackedTraditions } from '../../data/tcr';

export async function getStaticPaths() {
  const paths: { params: { book: string; chapter: string } }[] = [];
  for (const b of getAvailableBooks()) {
    for (const n of getAllChapterNums(b.slug)) {
      paths.push({ params: { book: b.slug, chapter: String(n) } });
    }
  }
  return paths;
}

const { book: bookSlug, chapter } = Astro.params;
const book = getBook(bookSlug!)!;
const chapterNum = parseInt(chapter!, 10);
const chapterData = loadChapter(bookSlug!, chapterNum);

const prevChapter = chapterNum > 1 ? chapterNum - 1 : null;
const nextChapter = chapterNum < book.chapters ? chapterNum + 1 : null;

const firstVersePreview = chapterData.verses[0]?.rendering?.slice(0, 120) + '…';
const sourceLabel = SOURCE_TEXT_LABELS[book.sourceText];

// Verse stacking: load tradition data for this chapter
const stackedTraditions = getStackedTraditions(bookSlug!, chapterNum);
const totalTraditions = stackedTraditions.length;

// Count how many verses have at least one tradition entry
let versesWithTraditions = 0;
for (const verse of chapterData.verses) {
  const hasTradition = stackedTraditions.some(t => t.verses.has(verse.verse));
  if (hasTradition) versesWithTraditions++;
}
const shouldCollapse = versesWithTraditions > 10;
---

<Layout
  title={`${book.name} ${chapterNum}`}
  description={`${book.name} chapter ${chapterNum} — The Covenant Rendering: modern English from the ${sourceLabel}. ${firstVersePreview}`}
  canonical={`/${bookSlug}/${chapterNum}`}
>
  <div class="bg-gradient-to-b from-cream-100 to-cream-50 border-b border-cream-200">
    <div class="max-w-3xl mx-auto px-6 py-12">
      <div class="flex items-center gap-2 text-base text-stone-400 mb-5">
        <a href={`/${bookSlug}`} class="hover:text-teal-600 transition-colors">{book.name}</a>
        <span>/</span>
        <span class="text-stone-600">Chapter {chapterNum}</span>
      </div>

      <h1 class="font-serif text-4xl font-medium text-stone-800 mb-2">
        {book.name} {chapterNum}
      </h1>
      <p class="text-stone-600 text-base">
        {chapterData.verses.length} verses &bull; {sourceLabel}
        {totalTraditions > 0 && (
          <span class="inline-flex items-center gap-1 ml-3 px-2.5 py-0.5 rounded-full text-base font-medium bg-amber-50 text-amber-700 border border-amber-200">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            {totalTraditions} tradition{totalTraditions !== 1 ? 's' : ''} available
          </span>
        )}
      </p>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-6 py-8">

    {chapterData.preamble && (
      <details class="mb-10 group" open>
        <summary class="cursor-pointer select-none flex items-center gap-2 text-base font-semibold uppercase tracking-widest text-teal-600 mb-4 hover:text-teal-700 transition-colors">
          <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          Translator's Introduction
        </summary>
        <div class="bg-cream-50 border border-cream-200 rounded-xl p-6 sm:p-8 space-y-5 text-lg leading-relaxed text-stone-600">
          <div>
            <h3 class="text-base font-semibold uppercase tracking-wider text-stone-400 mb-1.5">What This Chapter Is About</h3>
            <p class="font-serif italic">{chapterData.preamble.summary}</p>
          </div>
          <div>
            <h3 class="text-base font-semibold uppercase tracking-wider text-stone-400 mb-1.5">What Makes This Chapter Remarkable</h3>
            <p>{chapterData.preamble.remarkable}</p>
          </div>
          <div>
            <h3 class="text-base font-semibold uppercase tracking-wider text-stone-400 mb-1.5">Translation Friction</h3>
            <p>{chapterData.preamble.friction}</p>
          </div>
          <div>
            <h3 class="text-base font-semibold uppercase tracking-wider text-stone-400 mb-1.5">Connections</h3>
            <p>{chapterData.preamble.connections}</p>
          </div>
        </div>
      </details>
    )}

    {chapterData.verses.map((verse) => (
      <div>
        <VerseCard verse={verse} chapterNum={chapterNum} bookName={book.name} showAll={true} />
        {totalTraditions > 0 && stackedTraditions.some(t => t.verses.has(verse.verse)) && (
          <TraditionStack
            traditions={stackedTraditions}
            verseNum={verse.verse}
            collapsed={shouldCollapse}
          />
        )}
      </div>
    ))}
  </div>

  <!-- Verse permalink highlight + copy script -->
  <script>
    function highlightTarget() {
      const hash = window.location.hash;
      if (!hash || !hash.startsWith('#v')) return;
      const el = document.querySelector(hash);
      if (!el) return;
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      el.classList.add('bg-teal-50/80');
      setTimeout(() => el.classList.remove('bg-teal-50/80'), 2500);
    }
    highlightTarget();
    window.addEventListener('hashchange', highlightTarget);

    document.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest('.verse-permalink');
      if (!btn) return;
      e.preventDefault();
      const path = btn.getAttribute('data-permalink');
      if (!path) return;
      const url = window.location.origin + path;
      navigator.clipboard.writeText(url).then(() => {
        const orig = btn.innerHTML;
        btn.innerHTML = `<svg class="w-3.5 h-3.5 text-teal-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>`;
        setTimeout(() => { btn.innerHTML = orig; }, 1500);
      });
    });
  </script>

  <div class="max-w-3xl mx-auto px-6 pb-16">
    <div class="flex items-center justify-between pt-8 border-t border-cream-200">
      {prevChapter ? (
        <a
          href={`/${bookSlug}/${prevChapter}`}
          class="flex items-center gap-2 text-base font-medium text-teal-600 hover:text-teal-700 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Chapter {prevChapter}
        </a>
      ) : (
        <a href={`/${bookSlug}`} class="text-base font-medium text-stone-400 hover:text-teal-600 transition-colors">
          &larr; All chapters
        </a>
      )}

      <a
        href={`https://github.com/bashonda2/the-covenant-rendering/issues/new?title=Error+in+${encodeURIComponent(book.name)}+${chapterNum}&body=Describe+the+issue+with+${encodeURIComponent(book.name)}+chapter+${chapterNum}:`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-base text-stone-300 hover:text-red-500 transition-colors"
      >
        Report an error
      </a>

      <a href={`/${bookSlug}`} class="text-base text-stone-400 hover:text-teal-600 transition-colors">
        {book.name} index
      </a>

      {nextChapter ? (
        <a
          href={`/${bookSlug}/${nextChapter}`}
          class="flex items-center gap-2 text-base font-medium text-teal-600 hover:text-teal-700 transition-colors"
        >
          Chapter {nextChapter}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ) : (
        <span class="text-base text-stone-300">End of {book.name}</span>
      )}
    </div>
  </div>
</Layout>
