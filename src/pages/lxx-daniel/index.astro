---
import Layout from '../../layouts/Layout.astro';
import { loadVariantChapter } from '../../data/tcr';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

const dataRoot = join(process.cwd(), 'src', 'data', 'lxx-daniel');

function loadDanielFile(filename: string): any {
  const file = join(dataRoot, filename);
  return JSON.parse(readFileSync(file, 'utf-8'));
}

// Variant chapters 1-12
const variantChapters = Array.from({ length: 12 }, (_, i) => {
  const ch = loadVariantChapter('lxx-daniel', i + 1);
  const variants = ch.verses.filter((v: any) => v.has_variant).length;
  const theological = ch.verses.filter((v: any) => v.significance === 'theological').length;
  const major = ch.verses.filter((v: any) => v.significance === 'major').length;
  return {
    slug: String(i + 1),
    label: `Chapter ${i + 1}`,
    verses: ch.verses.length,
    variants,
    theological,
    major,
    isAddition: false,
    summary: ch.preamble?.summary || '',
  };
});

// Additions and extra chapters
const additions = [
  { file: 'chapter-03-additions.json', slug: '3-additions', label: 'Chapter 3 Additions (Prayer of Azariah & Song of Three Young Men)' },
  { file: 'chapter-13.json', slug: '13', label: 'Chapter 13 (Susanna)' },
  { file: 'chapter-14.json', slug: '14', label: 'Chapter 14 (Bel and the Dragon)' },
].map((a) => {
  const ch = loadDanielFile(a.file);
  return {
    slug: a.slug,
    label: a.label,
    verses: ch.verses.length,
    variants: 0,
    theological: 0,
    major: 0,
    isAddition: true,
    summary: ch.preamble?.summary || '',
  };
});

const allEntries = [...variantChapters, ...additions];
const totalVerses = allEntries.reduce((s, c) => s + c.verses, 0);
const totalVariants = variantChapters.reduce((s, c) => s + c.variants, 0);
const totalTheological = variantChapters.reduce((s, c) => s + c.theological, 0);
---

<Layout
  title="Septuagint Daniel (LXX)"
  description="The Septuagint Daniel compared verse-by-verse against the Masoretic Text, including the deuterocanonical additions: Prayer of Azariah, Susanna, and Bel and the Dragon."
  canonical="/lxx-daniel"
>
  <div class="bg-gradient-to-b from-cream-100 to-cream-50 border-b border-cream-200">
    <div class="max-w-3xl mx-auto px-6 py-12">
      <div class="flex items-center gap-2 text-base text-stone-400 mb-5">
        <a href="/books" class="hover:text-teal-600 transition-colors">Library</a>
        <span>/</span>
        <span class="text-stone-600">Septuagint Variants</span>
      </div>

      <h1 class="font-serif text-4xl font-medium text-stone-800 mb-2">
        Septuagint Daniel
      </h1>
      <p class="text-lg text-stone-500 mb-4">LXX/Theodotion &mdash; Including the deuterocanonical additions</p>

      <div class="flex flex-wrap gap-4 text-base text-stone-500">
        <span>{totalVerses.toLocaleString()} verses</span>
        <span>&bull;</span>
        <span>{totalVariants} variants documented</span>
        <span>&bull;</span>
        <span>{totalTheological} theologically significant</span>
        <span>&bull;</span>
        <span>2nd c. BCE</span>
      </div>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-6 py-8">
    <div class="bg-cream-50 border border-cream-200 rounded-xl p-6 mb-10 text-lg leading-relaxed text-stone-600">
      <h2 class="text-base font-semibold uppercase tracking-wider text-stone-400 mb-3">About This Tradition</h2>
      <p class="mb-3">
        The Greek Daniel exists in two forms: the Old Greek (OG) and Theodotion's revision. Theodotion's text
        became the standard in the church and is the version preserved in most Septuagint manuscripts. Both
        versions include three additions absent from the Hebrew/Aramaic MT: the Prayer of Azariah and Song
        of the Three Young Men (inserted in chapter 3), Susanna (chapter 13), and Bel and the Dragon (chapter 14).
      </p>
      <p>
        Chapters 1&ndash;12 are presented as verse-by-verse variant comparisons against the MT. The three
        additions are standalone renderings since they have no MT counterpart.
      </p>
    </div>

    <h2 class="text-base font-semibold uppercase tracking-wider text-stone-400 mb-4">Chapters 1&ndash;12 (Variant Comparison)</h2>
    <div class="space-y-2 mb-10">
      {variantChapters.map((ch) => (
        <a
          href={`/lxx-daniel/${ch.slug}`}
          class="block p-4 rounded-lg border border-cream-200 hover:border-teal-200 hover:bg-cream-50 transition-colors"
        >
          <div class="flex items-center justify-between">
            <div>
              <span class="font-serif text-lg text-stone-800">{ch.label}</span>
              <span class="text-base text-stone-400 ml-3">{ch.verses} verses</span>
            </div>
            <div class="flex items-center gap-3 text-base">
              {ch.theological > 0 && (
                <span class="px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-medium">
                  {ch.theological} theological
                </span>
              )}
              {ch.major > 0 && (
                <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 font-medium">
                  {ch.major} major
                </span>
              )}
              <span class="text-stone-400">{ch.variants} variant{ch.variants !== 1 ? 's' : ''}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <h2 class="text-base font-semibold uppercase tracking-wider text-stone-400 mb-4">Deuterocanonical Additions</h2>
    <div class="space-y-2">
      {additions.map((ch) => (
        <a
          href={`/lxx-daniel/${ch.slug}`}
          class="block p-4 rounded-lg border border-teal-100 hover:border-teal-200 hover:bg-teal-50/30 transition-colors"
        >
          <div class="flex items-center justify-between">
            <div>
              <span class="font-serif text-lg text-stone-800">{ch.label}</span>
              <span class="text-base text-stone-400 ml-3">{ch.verses} verses</span>
            </div>
            <div class="flex items-center gap-3 text-base">
              <span class="px-2 py-0.5 rounded-full bg-teal-100 text-teal-700 font-medium">
                standalone
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
