---
import type { StackedTradition, StackedVerse } from '../data/tcr';

interface Props {
  traditions: StackedTradition[];
  verseNum: number;
  collapsed?: boolean;
}

const { traditions, verseNum, collapsed = false } = Astro.props;

// Gather all tradition entries that have content for this verse
const entries: { tradition: StackedTradition; verse: StackedVerse }[] = [];
for (const t of traditions) {
  const sv = t.verses.get(verseNum);
  if (sv && sv.hasContent) {
    entries.push({ tradition: t, verse: sv });
  }
}

if (entries.length === 0) return;

// Color mapping by tradition type / id
function getBorderColor(tradition: StackedTradition): string {
  // Manuscript traditions (DSS, LXX, Samaritan): amber
  if (tradition.id.startsWith('dss-') || tradition.id.startsWith('lxx-') || tradition.id.startsWith('samaritan-')) {
    return 'border-amber-300';
  }
  // Interpretive traditions (Targum): purple
  if (tradition.id.startsWith('targum-')) {
    return 'border-purple-300';
  }
  // Western tradition (Vulgate): blue
  if (tradition.id.startsWith('vulgate')) {
    return 'border-blue-300';
  }
  // Latter-day Saint tradition (JST): green
  if (tradition.id.startsWith('jst')) {
    return 'border-emerald-300';
  }
  return 'border-stone-300';
}

function getLabelColor(tradition: StackedTradition): string {
  if (tradition.id.startsWith('dss-') || tradition.id.startsWith('lxx-') || tradition.id.startsWith('samaritan-')) {
    return 'text-amber-700';
  }
  if (tradition.id.startsWith('targum-')) {
    return 'text-purple-700';
  }
  if (tradition.id.startsWith('vulgate')) {
    return 'text-blue-700';
  }
  if (tradition.id.startsWith('jst')) {
    return 'text-emerald-700';
  }
  return 'text-stone-600';
}

function getBadgeBg(tradition: StackedTradition): string {
  if (tradition.id.startsWith('dss-') || tradition.id.startsWith('lxx-') || tradition.id.startsWith('samaritan-')) {
    return 'bg-amber-100 text-amber-700';
  }
  if (tradition.id.startsWith('targum-')) {
    return 'bg-purple-100 text-purple-700';
  }
  if (tradition.id.startsWith('vulgate')) {
    return 'bg-blue-100 text-blue-700';
  }
  if (tradition.id.startsWith('jst')) {
    return 'bg-emerald-100 text-emerald-700';
  }
  return 'bg-stone-100 text-stone-600';
}
---

{collapsed ? (
  <details class="tradition-stack ml-4 mt-3 mb-6">
    <summary class="cursor-pointer select-none text-base font-medium text-stone-400 hover:text-teal-600 transition-colors flex items-center gap-1.5">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      {entries.length} tradition{entries.length !== 1 ? 's' : ''} available
    </summary>
    <div class="mt-2 space-y-2">
      {entries.map(({ tradition, verse }) => (
        <div class={`border-l-4 ${getBorderColor(tradition)} pl-4 py-2`}>
          <p class={`text-base font-semibold uppercase tracking-wider ${getLabelColor(tradition)} mb-1`}>
            {tradition.label}
            {verse.significance && (
              <span class={`ml-2 px-1.5 py-0.5 rounded text-sm normal-case tracking-normal ${getBadgeBg(tradition)}`}>
                {verse.significance}
              </span>
            )}
            {verse.category && (
              <span class={`ml-2 px-1.5 py-0.5 rounded text-sm normal-case tracking-normal ${getBadgeBg(tradition)}`}>
                {verse.category}
              </span>
            )}
          </p>

          {/* Variant text (DSS, LXX, Samaritan) */}
          {verse.variantRendering && (
            <p class="text-stone-700 text-lg leading-relaxed font-serif italic">
              "{verse.variantRendering}"
            </p>
          )}

          {/* Targum/Vulgate rendering */}
          {verse.traditionRendering && (
            <p class="text-stone-700 text-lg leading-relaxed font-serif italic">
              "{verse.traditionRendering}"
            </p>
          )}

          {/* JST change summary */}
          {verse.changeSummary && (
            <p class="text-stone-700 text-lg leading-relaxed">
              {verse.changeSummary}
            </p>
          )}

          {/* Theological legacy (Vulgate) */}
          {verse.theologicalLegacy && (
            <p class="text-stone-500 text-base mt-1 leading-relaxed">
              {verse.theologicalLegacy}
            </p>
          )}

          {/* Notes */}
          {verse.notes && verse.notes.length > 0 && !verse.theologicalLegacy && (
            <p class="text-stone-500 text-base mt-1 leading-relaxed">
              {verse.notes[0]}
            </p>
          )}
        </div>
      ))}
    </div>
  </details>
) : (
  <div class="ml-4 mt-3 mb-6 space-y-2">
    {entries.map(({ tradition, verse }) => (
      <div class={`border-l-4 ${getBorderColor(tradition)} pl-4 py-2`}>
        <p class={`text-base font-semibold uppercase tracking-wider ${getLabelColor(tradition)} mb-1`}>
          {tradition.label}
          {verse.significance && (
            <span class={`ml-2 px-1.5 py-0.5 rounded text-sm normal-case tracking-normal ${getBadgeBg(tradition)}`}>
              {verse.significance}
            </span>
          )}
          {verse.category && (
            <span class={`ml-2 px-1.5 py-0.5 rounded text-sm normal-case tracking-normal ${getBadgeBg(tradition)}`}>
              {verse.category}
            </span>
          )}
        </p>

        {/* Variant text (DSS, LXX, Samaritan) */}
        {verse.variantRendering && (
          <p class="text-stone-700 text-lg leading-relaxed font-serif italic">
            "{verse.variantRendering}"
          </p>
        )}

        {/* Targum/Vulgate rendering */}
        {verse.traditionRendering && (
          <p class="text-stone-700 text-lg leading-relaxed font-serif italic">
            "{verse.traditionRendering}"
          </p>
        )}

        {/* JST change summary */}
        {verse.changeSummary && (
          <p class="text-stone-700 text-lg leading-relaxed">
            {verse.changeSummary}
          </p>
        )}

        {/* Theological legacy (Vulgate) */}
        {verse.theologicalLegacy && (
          <p class="text-stone-500 text-base mt-1 leading-relaxed">
            {verse.theologicalLegacy}
          </p>
        )}

        {/* Notes */}
        {verse.notes && verse.notes.length > 0 && !verse.theologicalLegacy && (
          <p class="text-stone-500 text-base mt-1 leading-relaxed">
            {verse.notes[0]}
          </p>
        )}
      </div>
    ))}
  </div>
)}
