---
import '../styles/global.css';
import { getAvailableBooks, getSectionsByTestament, getBooksBySection, type BookInfo } from '../data/tcr';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = 'The Covenant Rendering — a free, open-source modern English Bible translation from the Hebrew (WLC). Scholarly, transparent, developer-friendly. CC-BY-4.0.',
  canonical,
} = Astro.props;

const siteUrl = 'https://thecovenantrendering.com';
const resolvedCanonical = canonical ? `${siteUrl}${canonical}` : siteUrl;

const availableBooks = getAvailableBooks();
const otSections = getSectionsByTestament('old');
const ntSections = getSectionsByTestament('new');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | The Covenant Rendering</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <meta property="og:title" content={`${title} | The Covenant Rendering`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:type" content="website" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600&family=Noto+Serif+Hebrew:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex flex-col min-h-screen">
    <header class="border-b border-cream-200 bg-cream-50/95 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <span class="text-teal-600 text-xl font-serif font-medium tracking-wide group-hover:text-teal-700 transition-colors">
            The Covenant Rendering
          </span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1 text-sm font-medium">
          <!-- Books mega-menu -->
          <div class="relative group/books">
            <button class="px-4 py-2 text-stone-600 hover:text-teal-600 hover:bg-teal-50 rounded-lg transition-colors flex items-center gap-1">
              Books
              <svg class="w-3.5 h-3.5 opacity-50 group-hover/books:opacity-100 transition-opacity" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute right-0 top-full pt-1 opacity-0 invisible group-hover/books:opacity-100 group-hover/books:visible transition-all duration-150">
              <div class="bg-white border border-cream-200 rounded-xl shadow-xl py-5 px-6 min-w-[540px]">
                <div class="grid grid-cols-2 gap-6">
                  <!-- Old Testament -->
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-stone-400 mb-3">Old Testament</p>
                    <div class="space-y-3">
                      {otSections.map((sec) => {
                        const books = getBooksBySection(sec.id);
                        return (
                          <div>
                            <p class="text-[10px] font-semibold uppercase tracking-wider text-teal-600 mb-1">{sec.name}</p>
                            <div class="space-y-0.5">
                              {books.map((b: BookInfo) => (
                                b.status === 'complete' ? (
                                  <a
                                    href={`/${b.slug}`}
                                    class="block px-2 py-1 text-sm text-stone-700 hover:text-teal-600 hover:bg-teal-50 rounded transition-colors"
                                  >
                                    {b.name}
                                  </a>
                                ) : (
                                  <span class="block px-2 py-1 text-sm text-stone-300">{b.name}</span>
                                )
                              ))}
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                  <!-- New Testament -->
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-stone-400 mb-3">New Testament</p>
                    <div class="space-y-3">
                      {ntSections.map((sec) => {
                        const books = getBooksBySection(sec.id);
                        return (
                          <div>
                            <p class="text-[10px] font-semibold uppercase tracking-wider text-teal-600 mb-1">{sec.name}</p>
                            <div class="space-y-0.5">
                              {books.map((b: BookInfo) => (
                                b.status === 'complete' ? (
                                  <a
                                    href={`/${b.slug}`}
                                    class="block px-2 py-1 text-sm text-stone-700 hover:text-teal-600 hover:bg-teal-50 rounded transition-colors"
                                  >
                                    {b.name}
                                  </a>
                                ) : (
                                  <span class="block px-2 py-1 text-sm text-stone-300">{b.name}</span>
                                )
                              ))}
                            </div>
                          </div>
                        );
                      })}
                    </div>
                    <div class="mt-4 pt-3 border-t border-cream-200">
                      <a href="/books" class="block px-2 py-1.5 text-sm font-medium text-teal-600 hover:text-teal-700 hover:bg-teal-50 rounded transition-colors">
                        Full Bible &amp; Extended Library &rarr;
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <a href="/books" class="px-4 py-2 text-stone-600 hover:text-teal-600 hover:bg-teal-50 rounded-lg transition-colors">
            Library
          </a>

          <a href="/about" class="px-4 py-2 text-stone-600 hover:text-teal-600 hover:bg-teal-50 rounded-lg transition-colors">
            About
          </a>
          <a
            href="https://github.com/bashonda2/the-covenant-rendering"
            target="_blank"
            rel="noopener noreferrer"
            class="ml-2 px-4 py-2 text-teal-600 border border-teal-600 rounded-lg hover:bg-teal-600 hover:text-white transition-colors"
          >
            GitHub
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-stone-600 hover:text-teal-600 transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-cream-200 bg-cream-50 max-h-[75vh] overflow-y-auto">
        <div class="px-6 py-4 space-y-4">
          <!-- OT sections -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-stone-400 mb-2">Old Testament</p>
            {otSections.map((sec) => {
              const books = getBooksBySection(sec.id);
              const hasAvailable = books.some((b: BookInfo) => b.status === 'complete');
              return hasAvailable ? (
                <div class="mb-2">
                  <p class="text-[10px] font-semibold uppercase tracking-wider text-teal-600 mb-1 px-3">{sec.name}</p>
                  {books.filter((b: BookInfo) => b.status === 'complete').map((b: BookInfo) => (
                    <a
                      href={`/${b.slug}`}
                      class="flex items-center justify-between px-3 py-2 text-sm text-stone-700 hover:bg-teal-50 hover:text-teal-600 rounded-lg transition-colors"
                    >
                      <span class="font-medium">{b.name}</span>
                      {b.hebrewName && <span class="text-xs text-stone-400 font-serif">{b.hebrewName}</span>}
                    </a>
                  ))}
                </div>
              ) : null;
            })}
          </div>
          <div class="pt-3 mt-3 border-t border-cream-200 space-y-1">
            <a href="/books" class="block px-3 py-2.5 text-sm text-teal-600 hover:bg-teal-50 rounded-lg transition-colors font-medium">
              Full Bible &amp; Extended Library
            </a>
            <a href="/about" class="block px-3 py-2.5 text-sm text-stone-700 hover:bg-teal-50 hover:text-teal-600 rounded-lg transition-colors font-medium">
              About
            </a>
            <a
              href="https://github.com/bashonda2/the-covenant-rendering"
              target="_blank"
              rel="noopener noreferrer"
              class="block px-3 py-2.5 text-sm text-teal-600 hover:bg-teal-50 rounded-lg transition-colors font-medium"
            >
              GitHub
            </a>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-cream-200 mt-24">
      <div class="max-w-5xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-3 gap-10 text-sm text-stone-500">
        <div>
          <p class="font-serif text-base text-stone-700 mb-2">The Covenant Rendering</p>
          <p class="leading-relaxed">
            A free, modern English Bible translation from the original Hebrew and Greek.
            Released under CC-BY-4.0.
          </p>
        </div>
        <div>
          <p class="font-semibold text-stone-600 mb-3 uppercase tracking-wider text-xs">Browse</p>
          <ul class="space-y-2">
            {availableBooks.map((b) => (
              <li><a href={`/${b.slug}`} class="hover:text-teal-600 transition-colors">{b.name}</a></li>
            ))}
            <li><a href="/books" class="hover:text-teal-600 transition-colors">Full Library</a></li>
            <li><a href="/about" class="hover:text-teal-600 transition-colors">About the Translation</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-stone-600 mb-3 uppercase tracking-wider text-xs">Open Source</p>
          <ul class="space-y-2">
            <li>
              <a
                href="https://github.com/bashonda2/the-covenant-rendering"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-teal-600 transition-colors"
              >
                GitHub Repository
              </a>
            </li>
            <li>
              <a
                href="https://creativecommons.org/licenses/by/4.0/"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-teal-600 transition-colors"
              >
                CC-BY-4.0 License
              </a>
            </li>
            <li>
              <a
                href="mailto:contact@thecovenantrendering.com"
                class="hover:text-teal-600 transition-colors"
              >
                Feedback &amp; Contact
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-cream-200 py-5 text-center text-xs text-stone-400">
        <p>
          &copy; {new Date().getFullYear()} The Covenant Rendering. Source texts: Westminster Leningrad Codex &bull; SBL Greek New Testament.
          Translation generated with Claude (Anthropic) &mdash; methodology fully disclosed.
        </p>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
